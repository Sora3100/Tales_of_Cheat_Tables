local edit_memrec = getAddressList().getMemoryRecordByID("118205")
local old_arte_size = 0
local old_skill_size = 0

local arte_frequency_names = {"Neutral use (0%-100% HP)","Counter (0%-25% HP)","Counter (25%-50% HP)","Counter (50%-100% HP)","Counter while guarding (0%-25% HP)","Counter while guarding (25%-50% HP)","Counter while guarding (50%-100% HP)","After knockdown","During link (as partner) while target is behind leader","HP Recovery (0%-75% HP)","On target knockdown","On target stagger","On target stun","On target passing by/above character","On target guarding","Over Limit neutral use (0%-25% HP)","Over Limit neutral use (25%-50% HP)","Over Limit neutral use (50%-100% HP)","During link (as leader)","During link (as partner) while leader is being attacked","During link (as partner) while target is behind leader OR leader is being attacked","Neutral use (0%-25% HP)","Neutral use (25%-50% HP)"}

--print("Method: "..toHex(method)..", instance: "..toHex(instance))

local args = {}
args[1] = {}
args[1].type = vtDword

local arte_table_memrec = getAddressList().getMemoryRecordByID("118207")
local skill_table_memrec = getAddressList().getMemoryRecordByID("118208")

edit_memrec.OnValueChanged = function(memrec, oldValue, newValue)
                           args[1].value = tonumber(newValue)
                           local result = mono_invoke_method(nil, method, nil, args)

                           if (result == nil) then goto _stop end
                           --print("Result: "..toHex(result))
                           writeQword("tbl_data+78", result)

                           -----------------------------------------------------------------------------
                           local new_arte_size = readInteger(readPointer(result + 0x18) + 0x18)
                           --print("New skill size: "..new_skill_size)

                           if (new_arte_size &gt; 100) then goto _artebreak end

                           if (old_arte_size &gt; new_arte_size) then
                              --delete
                              for i = arte_table_memrec.Count - 1, new_arte_size, -1 do
                                  arte_table_memrec.Child[i].Destroy()
                              end
                           elseif (old_arte_size &lt; new_arte_size) then
                                  --create
                                  for i = arte_table_memrec.Count, new_arte_size - 1, 1 do
                                      local header = getAddressList().createMemoryRecord()

                                      header.beginEdit()
                                      header.Description = "Arte "..(i + 1)
                                      header.Address = "+0"
                                      header.OffsetCount = 3
                                      header.Offset[0] = 0x0
                                      header.Offset[1] = 0x20 + 0x8 * i
                                      header.Offset[2] = 0x10
                                      header.IsGroupHeader = true
                                      header.IsAddressGroupHeader = true
                                      header.Options = "[moHideChildren]"
                                      header.DontSave = true
                                      header.appendToEntry(arte_table_memrec)
                                      header.endEdit()

                                      local memrec = getAddressList().createMemoryRecord()

                                      memrec.beginEdit()
                                      memrec.Description = "Arte"
                                      memrec.Address = "+10"
                                      memrec.Type = vtDword
                                      memrec.DropDownLinkedMemrec = "dropdown: Artes"
                                      memrec.DropDownLinked = true
                                      memrec.DontSave = true
                                      memrec.appendToEntry(header)
                                      memrec.endEdit()

                                      local memrec = getAddressList().createMemoryRecord()

                                      memrec.beginEdit()
                                      memrec.Description = "Direction"
                                      memrec.Address = "+14"
                                      memrec.Type = vtDword
                                      memrec.DontSave = true
                                      memrec.appendToEntry(header)
                                      memrec.endEdit()

                                      local memrec = getAddressList().createMemoryRecord()

                                      memrec.beginEdit()
                                      memrec.Description = "Difficulty"
                                      memrec.Address = "+18"
                                      memrec.Type = vtDword
                                      memrec.DropDownLinkedMemrec = "dropdown: Difficulties"
                                      memrec.DropDownLinked = true
                                      memrec.DontSave = true
                                      memrec.appendToEntry(header)
                                      memrec.endEdit()

                                      local freq_header = getAddressList().createMemoryRecord()

                                      freq_header.beginEdit()
                                      freq_header.Description = "Frequency pointer"
                                      freq_header.Address = "+20"
                                      freq_header.Type = vtQword
                                      freq_header.ShowAsHex = true
                                      freq_header.Options = "[moAllowManualCollapseAndExpand, moManualExpandCollapse]"
                                      freq_header.DontSave = true
                                      freq_header.appendToEntry(header)
                                      freq_header.endEdit()

                                      local freq_size = readPointer(result + 0x18)
                                      freq_size = readPointer(freq_size + 0x10)
                                      freq_size = readPointer(freq_size + 0x20 + 0x8 * i)
                                      freq_size = readPointer(freq_size + 0x20)
                                      freq_size = readInteger(freq_size + 0x18)

                                      if (freq_size &lt; 23) then print("Less than 23") end
                                      if (freq_size &gt; 23) then goto _artebreak end

                                      for j = 0, freq_size - 1, 1 do
                                          local memrec = getAddressList().createMemoryRecord()

                                          memrec.beginEdit()
                                          if ((j + 1) &gt; #arte_frequency_names) or ((j + 1) == 0) then
                                             memrec.Description = "Unknown"
                                          else
                                              memrec.Description = arte_frequency_names[j + 1]
                                          end
                                          memrec.Address = "+0"
                                          memrec.OffsetCount = 2
                                          memrec.Offset[0] = 0x20 + 0x4 * j
                                          memrec.Offset[1] = 0x10
                                          memrec.Type = vtDword
                                          memrec.DontSave = true
                                          memrec.appendToEntry(freq_header)
                                          memrec.endEdit()
                                      end
                                  end
                           end

                           ::_artebreak::
                           old_arte_size = new_arte_size
                           -----------------------------------------------------------------------------
                           local new_skill_size = readInteger(readPointer(result + 0x20) + 0x18)
                           --print("New skill size: "..new_skill_size)

                           if (new_skill_size &gt; 100) then goto _skillbreak end

                           if (old_skill_size &gt; new_skill_size) then
                              --delete
                              for i = skill_table_memrec.Count - 1, new_skill_size, -1 do
                                  skill_table_memrec.Child[i].Destroy()
                              end
                           elseif (old_skill_size &lt; new_skill_size) then
                                  --create
                                  for i = skill_table_memrec.Count, new_skill_size - 1, 1 do
                                      local header = getAddressList().createMemoryRecord()

                                      header.beginEdit()
                                      header.Description = "Skill "..(i + 1)
                                      header.Address = "+0"
                                      header.OffsetCount = 3
                                      header.Offset[0] = 0x0
                                      header.Offset[1] = 0x20 + 0x8 * i
                                      header.Offset[2] = 0x10
                                      header.IsGroupHeader = true
                                      header.IsAddressGroupHeader = true
                                      header.Options = "[moHideChildren]"
                                      header.DontSave = true
                                      header.appendToEntry(skill_table_memrec)
                                      header.endEdit()

                                      local memrec = getAddressList().createMemoryRecord()

                                      memrec.beginEdit()
                                      memrec.Description = "Skill"
                                      memrec.Address = "+10"
                                      memrec.Type = vtDword
                                      memrec.DropDownLinkedMemrec = "dropdown: Skills"
                                      memrec.DropDownLinked = true
                                      memrec.DontSave = true
                                      memrec.appendToEntry(header)
                                      memrec.endEdit()

                                      local memrec = getAddressList().createMemoryRecord()

                                      memrec.beginEdit()
                                      memrec.Description = "Difficulty"
                                      memrec.Address = "+14"
                                      memrec.Type = vtDword
                                      memrec.DropDownLinkedMemrec = "dropdown: Difficulties"
                                      memrec.DropDownLinked = true
                                      memrec.DontSave = true
                                      memrec.appendToEntry(header)
                                      memrec.endEdit()
                                  end
                           end

                           ::_skillbreak::
                           old_skill_size = new_skill_size

                           ::_stop::
end
{$asm}
