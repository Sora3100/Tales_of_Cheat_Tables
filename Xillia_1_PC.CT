<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="45">
  <CheatEntries>
    <CheatEntry>
      <ID>3</ID>
      <Description>"Enable"</Description>
      <Options moHideChildren="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{$STRICT}
define(bytes, 48 83 EC 28 4C 8B 41 38 44 8B CA 0F 1F 44 00 00)
{$lua}
if syntaxcheck then return end

function toHex(str)
  return string.format("%X", str)
end

function get_mono_method(image_name, namespace, class_name, method_name)
  if (namespace == nil) or (class_name == nil) or (method_name == "") or (method_name == nil) then
     print("An argument was not specified for get_mono_method()")
     return 0
  end
  if (image_name == "") or (image_name == nil) then
     image_name = "Assembly-CSharp.dll"
  end

  local assems = mono_enumAssemblies()
  local class = nil
  local method = nil
  local count = 0
  local instance = nil

  for i, addr in ipairs(assems) do
      local image = mono_getImageFromAssembly(addr)
      local img_name = mono_image_get_name(image)

      if (img_name == image_name) then
         --print("Got Assembly-CSharp")
         local classes = mono_image_enumClasses(image)
         for j, cls_addr in ipairs(classes) do
            if (classes[j].namespace == namespace) then
               --print("Found namespace")
               if (classes[j].classname == class_name) then
                  --print("Found class")
                  class = classes[j].class
                  local methods = mono_class_enumMethods(class)

                  for k, name_of_method in ipairs(methods) do
                      if (methods[k].name == method_name) then
                         method = methods[k].method
                         instances = mono_class_findInstancesOfClassListOnly(nil, class)

                         for n, value in ipairs(instances) do
                             --print(n..": "..toHex(value))
                             count = count + 1
                         end

                         --print(toHex(instances[count]))
                         return method, instances[count]
                      end
                  end
               end
            end
         end
      end
  end

  return 0, 0
end
{$asm}
[ENABLE]
{$lua}
if syntaxcheck then return end
if process and readInteger(process) ~= 0 then
   if (monopipe ~= nil) and (monopipe.ProcessID ~= getOpenedProcessID()) then
      monopipe.Destroy()
      monopipe = nil
   end
   if (monopipe == nil) then
      LaunchMonoDataCollector()
      --wait for mono
      while (monoSymbolList == nil) or (not monoSymbolList.FullyLoaded) do
            checkSynchronize(50)
      end
   end
end

if (script_tbl == nil) then
    script_tbl = {}
end

local function mainloop()
               --if (readInteger(process) == nil) then
                  --timer.Enabled = false
                  --timer.Destroy()
                  --tiemer = nil
                  --memrec.Active = false
                  --if (memrec.Active == true) then
                  --   memrec.disableWithoutExecute()
                  --end
               if (getOpenedProcessID() ~= 0) and not (readInteger(process) == nil) then
                  --execute scripts
                  for i in pairs(script_tbl) do
                      --print("Executing script "..i..": "..script_tbl[i])
                      _G[script_tbl[i]]()
                  end
               else
                   script_tbl = {}
                   timer.enabled = false
                   timer.Destroy()
                   timer = nil
               end
end

if not timer then
   timer = createTimer(nil)
   timer.OnTimer = function(timer)
                   mainloop()
                   end
   timer.Interval = 1000
   timer.Enabled = true
else
   timer.Enabled = true
end
{$asm}
alloc(tbl_data,$1000)

tbl_data+8: //character selected
  dq 1

registersymbol(tbl_data)

assert(CPartyOrder.Check, bytes)

alloc(newmem,$1000)

label(code)
label(return)

newmem:
  push rax
  mov rax,tbl_data
  mov [rax],rcx
  pop rax
code:
  db bytes
  jmp return

CPartyOrder.Check:
  jmp newmem
  nop 2

return:
[DISABLE]
{$lua}
if syntaxcheck then return end
if (timer) then
   timer.Enabled = false
   timer.Destroy()
   timer = nil
end
{$asm}
CPartyOrder.Check:
  db bytes

dealloc(newmem)
unregistersymbol(tbl_data)
dealloc(tbl_data)
