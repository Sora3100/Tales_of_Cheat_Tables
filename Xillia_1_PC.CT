              <AssemblerScript>{$lua}
if syntaxcheck then return end
local method, instance = get_mono_method("Assembly-CSharp.dll", "BTL", "TO11BtlDatabase", "GetUnitStatus")
local edit_memrec = getAddressList().getMemoryRecordByID("116576")

local args = {}
args[1] = {}
args[1].type = vtDword

edit_memrec.OnValueChanged = function(memrec, oldValue, newValue)
                           args[1].value = tonumber(newValue)
                           local result = mono_invoke_method(nil, method, nil, args)
                           writeQword("tbl_data+38", result)
end
{$asm}
{$STRICT}
define(bytes, 0F 57 C0 33 C0 0F 11 44 24 40 48 89 44 24 50 83 FB FF)
[ENABLE]

assert(MonsterDetailList.SetViewMonsterData+11F, bytes)

alloc(newmem,$1000)

label(code)
label(return)

tbl_data+30: //enable hover
  dq 1

newmem:
  mov rax,tbl_data
  cmp [rax+30],0 //hover check
  je code
  mov [rax+28],rbx
code:
  xorps xmm0,xmm0
  xor eax,eax
  movups [rsp+40],xmm0
  mov [rsp+50],rax
  jmp return

MonsterDetailList.SetViewMonsterData+11F:
  jmp newmem
  nop

return:
[DISABLE]
{$lua}
if syntaxcheck then return end
local edit_memrec = getAddressList().getMemoryRecordByID("116576")
edit_memrec = nil
{$asm}

MonsterDetailList.SetViewMonsterData+11f:
  db bytes

dealloc(newmem)
