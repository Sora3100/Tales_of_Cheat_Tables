              <ID>118184</ID>
              <Description>"Encounter Group editor"</Description>
              <Options moHideChildren="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
local method, instance = get_mono_method("Assembly-CSharp.dll", "BTL", "TO11BtlDatabase", "GetEncounterGroupByIndex")
local edit_memrec = getAddressList().getMemoryRecordByID("118185")
local old_member_size = 0

--print("Method: "..toHex(method)..", instance: "..toHex(instance))

local args = {}
args[1] = {}
args[1].type = vtDword

local member_memrec = getAddressList().getMemoryRecordByID("118196")

edit_memrec.OnValueChanged = function(memrec, oldValue, newValue)
                           args[1].value = tonumber(newValue)
                           local result = mono_invoke_method(nil, method, nil, args)

                           if (result == nil) then goto _stop end
                           --print("Result: "..toHex(result))
                           writeQword("tbl_data+68", result)

                           local new_member_size = readInteger(readPointer(result + 0x38) + 0x18)
                           --print("New member size: "..new_member_size)

                           if (new_member_size &gt; 100) then goto _break end

                           if (old_member_size &gt; new_member_size) then
                              --delete
                              --print("New: "..new_member_size..", old: "..old_member_size)

                              for i = member_memrec.Count - 1, new_member_size, -1 do
                                  --print(member_memrec.Child[i].Description.." destroyed")
                                  --no idea why this causes access violation still
                                  member_memrec.Child[i].Destroy()
                              end
                           elseif (old_member_size &lt; new_member_size) then
                                  --create
                                  for i = member_memrec.Count, new_member_size - 1, 1 do
                                      --print("Creating memrec "..(i + 1))
                                      local memrec = getAddressList().createMemoryRecord()

                                      memrec.beginEdit()
                                      memrec.Description = "Member "..(i + 1)
                                      memrec.Address = "+0"
                                      memrec.OffsetCount = 3
                                      memrec.Offset[0] = 0x10
                                      memrec.Offset[1] = 0x20 + 0x8 * toHex(i)
                                      memrec.Offset[2] = 0x10
                                      memrec.Type = vtDword
                                      memrec.DropDownLinkedMemrec = "dropdown: Enemy List"
                                      memrec.DropDownLinked = true
                                      memrec.DontSave = true
                                      memrec.appendToEntry(member_memrec)
                                      memrec.endEdit()
                                  end
                           end

                           ::_break::
                           old_member_size = new_member_size

                           ::_stop::
end
{$asm}
