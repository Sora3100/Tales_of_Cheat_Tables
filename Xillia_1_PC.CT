{$STRICT}
define(bytes, 0F 57 C0 33 C0 0F 11 44 24 40 48 89 44 24 50 83 FB FF)
[ENABLE]

assert(MonsterDetailList.SetViewMonsterData+11F, bytes)

alloc(newmem,$1000)

label(code)
label(return)

tbl_data+30: //enable hover
  dq 1

newmem:
  mov rax,tbl_data
  cmp [rax+30],0 //hover check
  je code
  mov [rax+28],rbx
code:
  xorps xmm0,xmm0
  xor eax,eax
  movups [rsp+40],xmm0
  mov [rsp+50],rax
  jmp return

MonsterDetailList.SetViewMonsterData+11F:
  jmp newmem
  nop

return:
