            <CheatEntry>
              <ID>118536</ID>
              <Description>"Wingul fight editor (does not work)"</Description>
              <Options moHideChildren="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

if (readQword("tbl_data+80") == 0) then
  local method, instance = get_mono_method("Assembly-CSharp.dll", "BTL", "TO11BtlDatabase", "GetEncounterGroupByIndex")

  local args = {}
  args[1] = {}
  args[1].type = vtDword
  args[1].value = 62

  local result = mono_invoke_method(nil, method, nil, args)
  writeQword("tbl_data+80", result)
end

local wingul_fight_edit_mem_newmem = allocateMemory(0x1000)
registerSymbol("wingul_fight_edit_mem", wingul_fight_edit_mem_newmem)

local enemy_count_memrec = getAddressList().getMemoryRecordByID("118554")
local enemy_header_memrec = getAddressList().getMemoryRecordByID("118558")

local pointer_to_members = readPointer(getAddress("tbl_data+80")) --aka result
pointer_to_members = readPointer(pointer_to_members + 0x38)
pointer_to_members = readPointer(pointer_to_members + 0x10)
pointer_to_members = pointer_to_members + 0x20
writeQword(wingul_fight_edit_mem_newmem, pointer_to_members) --pos
writeQword(wingul_fight_edit_mem_newmem + 0x8, readPointer(pointer_to_members)) --value

--print("Pointer pos: 0x"..toHex(pointer_to_members)..", value: 0x"..toHex(readPointer(pointer_to_members)))

writeQword(wingul_fight_edit_mem_newmem + 0x10, readPointer(readPointer(pointer_to_members))) --copy pointer to new mem
writeQword(pointer_to_members, wingul_fight_edit_mem_newmem + 0x10) --write new pointer
writeInteger(wingul_fight_edit_mem_newmem + 0x20, 262) --write back Wingul enemy

enemy_count_memrec.OnValueChanged = function(memrec, oldValue, newValue)
                                  oldValue = tonumber(oldValue)
                                  newValue = tonumber(newValue)

                                  if (newValue &gt; 100) then goto _break end

                                  if (oldValue &gt; newValue) then
                                    --delete
                                    for i = enemy_header_memrec.Count - 1, newValue, -1 do
                                        enemy_header_memrec.Child[i].Destroy()
                                    end
                                  elseif (oldValue &lt; newValue) then
                                        --create
                                        for i = enemy_header_memrec.Count, newValue - 1, 1 do
                                            local memrec = getAddressList().createMemoryRecord()

                                            memrec.beginEdit()
                                            memrec.Description = "Enemy "..(i + 1)
                                            memrec.Address = "+0"
                                            memrec.OffsetCount = 2
                                            memrec.Offset[0] = 0x10
                                            memrec.Offset[1] = 0x20 + 0x8 * i
                                            memrec.Type = vtDword
                                            memrec.DropDownLinkedMemrec = "dropdown: Enemy List"
                                            memrec.DropDownLinked = true
                                            memrec.DontSave = true
                                            memrec.appendToEntry(enemy_header_memrec)
                                            memrec.endEdit()
                                        end
                                  end

::_break::
end
{$asm}
