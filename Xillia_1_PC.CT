            <CheatEntry>
              <ID>118535</ID>
              <Description>"Show all entries in Enemy Book (broken due to remaster being worse than PS3)"</Description>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$STRICT}
define(bytes, 48 89 5C 24 08 48 89 6C 24 10 48 89 74 24 18 57 48 83 EC 20)
define(bytes2, 48 89 5C 24 08 57 48 83 EC 20)
[ENABLE]
assert(MonsterReportList.UpdateList, bytes)
assert(TO11.CEnemyProfile.IsEncounter, bytes2)

MonsterReportList.UpdateList+ED: //bBook
  nop 2

//TO11.CEnemyProfile.IsEncounter+6D: //fought
//  mov al,1
//  nop

[DISABLE]

MonsterReportList.UpdateList+ED: //bBook
  db 74 4C

//TO11.CEnemyProfile.IsEncounter+6D: //fought
//  db 0F 97 C0
</AssemblerScript>
