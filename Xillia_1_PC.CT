            <CheatEntry>
              <ID>118023</ID>
              <Description>"Arte properties editor"</Description>
              <Options moHideChildren="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$STRICT}
define(bytes,48 89 5C 24 08 48 89 74 24 18 57 48 83 EC 60 48 63 DA 48 8B F1)
[ENABLE]
{$lua}
if syntaxcheck then return end
local method, instance = get_mono_method("Assembly-CSharp.dll", "BTL", "TO11BtlDatabase", "GetMagicArts")
local edit_memrec = getAddressList().getMemoryRecordByID("116535")

--print("Method: "..toHex(method)..", instance: "..toHex(instance))

local args = {}
args[1] = {}
args[1].type = vtDword

edit_memrec.OnValueChanged = function(memrec, oldValue, newValue)
                           args[1].value = tonumber(newValue)
                           local result = mono_invoke_method(nil, method, nil, args)
                           --print("Result: "..toHex(result))
                           writeQword("tbl_data+18", result)
end
{$asm}
aobscanmodule(arte_prop_ptr,GameAssembly.dll,41 8B 45 30 48 ? ? ? ? ? ? 89 44 24 50 FF C8 83 F8 08) // should be unique
alloc(newmem,$1000,arte_prop_ptr)
alloc(arte_prop_ptr_original_bytes,$1000)

label(code)
label(return)

arte_prop_ptr_original_bytes:
  readMem(arte_prop_ptr, 20)

tbl_data+20: //enable hover
  dq 1

newmem:
  mov rax,tbl_data
  cmp [rax+20],0
  je code
  mov [rax+10],rsi
code:
  mov eax,[r13+30]
  reassemble(arte_prop_ptr+4)
  //lea rsi,[7FF82FCC0000]
  mov [rsp+50],eax
  dec eax
  cmp eax,08
  jmp return

arte_prop_ptr:
  jmp newmem
  nop F
return:
registersymbol(arte_prop_ptr)
registersymbol(arte_prop_ptr_original_bytes)
[DISABLE]
{$lua}
if syntaxcheck then return end
local edit_memrec = getAddressList().getMemoryRecordByID("116535")
edit_memrec.OnValueChanged = nil
{$asm}

arte_prop_ptr:
  readMem(arte_prop_ptr_original_bytes, 20)

unregistersymbol(arte_prop_ptr)
unregistersymbol(arte_prop_ptr_original_bytes)
dealloc(newmem)
dealloc(arte_prop_ptr_original_bytes)
</AssemblerScript>
