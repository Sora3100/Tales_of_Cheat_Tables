  <CheatEntries>
    <CheatEntry>
      <ID>135</ID>
      <Description>"Enable"</Description>
      <Options moHideChildren="1"/>
      <DropDownList DisplayValueAsItem="1">0:Dio/Nothing
1:Mell
2:Couleur
3:Cress
4:Mint
5:Chester
6:Arche
7:Klarth
8:Suzu
9:Rondoline
</DropDownList>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{$lua}
-- By "25094" on GitHub
function GetEmuBase()
local command = 0xB118
local emuHWND = findWindow("PPSSPPWnd")

local pointer = {}

local result = sendMessage(emuHWND, command, 0, 0)
pointer[1] = tonumber(result)

result = sendMessage(emuHWND, command, 0, 1)
pointer[2] = tonumber(result)

local lower = pointer[1]
local upper = pointer[2]
local combinedPointer = (upper * 0x100000000) + lower

return tonumber(combinedPointer)
end
{$asm}
[ENABLE]
{$lua}
if syntaxcheck then return end

if process and readInteger(process) and (string.lower(process):match("ppsspp")) then
   local ptr = GetEmuBase()

   if not (ptr == nil) and not (ptr == 0) then
      registerSymbol("PSP_base",ptr)
      registerSymbol("CWCheat_base",ptr+0x8800000)
   else
      showMessage("Using fallback... this may take a few seconds")

      local r, aaError = autoAssemble(
      [[aobscan(DataStart,? ? ? 27 21 68 A0 00)
      define(PSP_base, DataStart-0x8804000)
      define(CWCheat_base, DataStart-0x4000)
      registersymbol(PSP_base)
      registersymbol(CWCheat_base)]])

      if (r==false) then
         local errormsg = "Make sure the game is running!"

         showMessage(errormsg)
         error(errormsg)
      end
   end

   local mf = getMainForm()
   if (mf.FromAddress.Text == "0000000000000000") and (mf.ToAddress.Text == "00007fffffffffff") or (mf.ToAddress.Text == "7fffffffffffffff") then
      mf.FromAddress.Text = "PSP_base"
      mf.ToAddress.Text = "PSP_base+"..toHex(0x03FFFFFF)
   end
else
    local errormsg = "Not attached to PPSSPP"

    showMessage(errormsg)
    error(errormsg)
    return
end
{$asm}
[DISABLE]
unregistersymbol(PSP_base)
unregistersymbol(CWCheat_base)
