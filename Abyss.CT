[DISABLE]
{$lua}
if syntaxcheck then return end
BTSK_edit_memrec.DropDownList.Text = ""
BTSK_edit_memrec.OnValueChanged = nil
{$asm}
unregistersymbol(BTSK_v2)
//unregistersymbol(BTMG)
</AssemblerScript>
              <CheatEntries>
                <CheatEntry>
                  <ID>93149</ID>
                  <Description>"Edit"</Description>
                  <ShowAsHex>1</ShowAsHex>
                  <ShowAsSigned>0</ShowAsSigned>
                  <VariableType>8 Bytes</VariableType>
                  <Address>tbl_data+8</Address>
                  <CheatEntries>
                    <CheatEntry>
                      <ID>93308</ID>
                      <Description>"Frame Data"</Description>
                      <Options moHideChildren="1"/>
                      <ShowAsSigned>0</ShowAsSigned>
                      <GroupHeader>1</GroupHeader>
                      <Address>tbl_data+8</Address>
                      <Offsets>
                        <Offset>(DWORD)[(QWORD)[tbl_data+8]+10]</Offset>
                      </Offsets>
                    </CheatEntry>
                    <CheatEntry>
                      <ID>93490</ID>
                      <Description>"Hit Data"</Description>
                      <Options moHideChildren="1"/>
                      <ShowAsSigned>0</ShowAsSigned>
                      <GroupHeader>1</GroupHeader>
                      <Address>tbl_data+8</Address>
                      <Offsets>
                        <Offset>(DWORD)[(QWORD)[tbl_data+8]+94]</Offset>
                      </Offsets>
                    </CheatEntry>
                    <CheatEntry>
                      <ID>93491</ID>
                      <Description>"State Machines"</Description>
                      <Options moHideChildren="1"/>
                      <ShowAsSigned>0</ShowAsSigned>
                      <GroupHeader>1</GroupHeader>
                      <Address>tbl_data+8</Address>
                      <Offsets>
                        <Offset>0</Offset>
                      </Offsets>
                    </CheatEntry>
                    <CheatEntry>
                      <ID>135895</ID>
                      <Description>"Projectile Data"</Description>
                      <Options moHideChildren="1"/>
                      <ShowAsSigned>0</ShowAsSigned>
                      <GroupHeader>1</GroupHeader>
                      <Address>tbl_data+8</Address>
                      <Offsets>
                        <Offset>(DWORD)[(QWORD)[tbl_data+8]+98]</Offset>
                      </Offsets>
                    </CheatEntry>
                  </CheatEntries>
                </CheatEntry>
              </CheatEntries>
            </CheatEntry>
            <CheatEntry>
              <ID>93395</ID>
              <Description>"Template"</Description>
              <Options moHideChildren="1"/>
              <GroupHeader>1</GroupHeader>
              <CheatEntries>
                <CheatEntry>
                  <ID>93396</ID>
                  <Description>"Frame Data"</Description>
                  <Options moHideChildren="1"/>
                  <GroupHeader>1</GroupHeader>
                  <CheatEntries>
                    <CheatEntry>
                      <ID>93233</ID>
                      <Description>"Frame to end anim"</Description>
                      <ShowAsSigned>0</ShowAsSigned>
                      <VariableType>2 Bytes</VariableType>
                      <Address>+0</Address>
                    </CheatEntry>
                    <CheatEntry>
                      <ID>93241</ID>
                      <Description>"Cooldown"</Description>
                      <ShowAsSigned>0</ShowAsSigned>
                      <VariableType>2 Bytes</VariableType>
                      <Address>+2</Address>
                    </CheatEntry>
