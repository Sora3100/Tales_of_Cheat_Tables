          <ID>91977</ID>
          <Description>"Asch equipment edit"</Description>
          <Options moHideChildren="1"/>
          <GroupHeader>1</GroupHeader>
          <CheatEntries>
            <CheatEntry>
              <ID>91974</ID>
              <Description>"Weapon"</Description>
              <DropDownListLink>dropdown: Disabled/Enabled</DropDownListLink>
              <ShowAsSigned>0</ShowAsSigned>
              <VariableType>Binary</VariableType>
              <BitStart>5</BitStart>
              <BitLength>1</BitLength>
              <ShowAsBinary>0</ShowAsBinary>
              <Address>baseElfAddr+D48A3C</Address>
            </CheatEntry>
            <CheatEntry>
              <ID>91975</ID>
              <Description>"Body"</Description>
              <DropDownListLink>dropdown: Disabled/Enabled</DropDownListLink>
              <ShowAsSigned>0</ShowAsSigned>
              <VariableType>Binary</VariableType>
              <BitStart>5</BitStart>
              <BitLength>1</BitLength>
              <ShowAsBinary>0</ShowAsBinary>
              <Address>baseElfAddr+D4B700</Address>
            </CheatEntry>
            <CheatEntry>
              <ID>91976</ID>
              <Description>"Other"</Description>
              <DropDownListLink>dropdown: Disabled/Enabled</DropDownListLink>
              <ShowAsSigned>0</ShowAsSigned>
              <VariableType>Binary</VariableType>
              <BitStart>5</BitStart>
              <BitLength>1</BitLength>
              <ShowAsBinary>0</ShowAsBinary>
              <Address>baseElfAddr+D4D35C</Address>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>
        <CheatEntry>
          <ID>93394</ID>
          <Description>"BTSK v2"</Description>
          <Options moHideChildren="1"/>
          <GroupHeader>1</GroupHeader>
          <CheatEntries>
            <CheatEntry>
              <ID>93146</ID>
              <Description>"Activate"</Description>
              <Options moHideChildren="1"/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local function copyMemRecRecursive(header, currTemplate)
      for i = 0, currTemplate.Count - 1, 1 do
          local memoryrecord = getAddressList().createMemoryRecord()

          memoryrecord.Description = currTemplate.Child[i].Description

          if (currTemplate.Child[i].IsAddressGroupHeader == false) and (currTemplate.Child[i].IsGroupHeader == true) then
             memoryrecord.IsGroupHeader = true
          elseif (currTemplate.Child[i].IsAddressGroupHeader == true) and (currTemplate.Child[i].IsGroupHeader == true) then
               memoryrecord.IsGroupHeader = true
               memoryrecord.IsAddressGroupHeader = true
          else
              memoryrecord.Type = currTemplate.Child[i].Type

              if (currTemplate.Child[i].Type == vtByte) or
              (currTemplate.Child[i].Type == vtWord) or
              (currTemplate.Child[i].Type == vtDword) or
              (currTemplate.Child[i].Type == vtQword) then
                 memoryrecord.ShowAsHex = currTemplate.Child[i].ShowAsHex
                 memoryrecord.ShowAsSigned = currTemplate.Child[i].ShowAsSigned
              elseif (currTemplate.Child[i].Type == vtString) then
                     memoryrecord.String.Size = currTemplate.Child[i].String.Size
                     memoryrecord.String.Unicode = currTemplate.Child[i].String.Unicode
                     memoryrecord.String.Codepage = currTemplate.Child[i].String.Codepage
              elseif (currTemplate.Child[i].Type == vtByteArray) then
                     memoryrecord.Aob.Size = currTemplate.Child[i].Aob.Size
                     memoryrecord.ShowAsHex = currTemplate.Child[i].ShowAsHex
              elseif (currTemplate.Child[i].Type == vtBinary) then
                     memoryrecord.Binary.Startbit = currTemplate.Child[i].Binary.Startbit
                     memoryrecord.Binary.Size = currTemplate.Child[i].Binary.Size
              elseif (currTemplate.Child[i].Type == vtAutoAssembler) then
                     memoryrecord.Script = currTemplate.Child[i].Script
              elseif (currTemplate.Child[i].Type == vtCustom) then
                     memoryrecord.CustomTypeName = currTemplate.Child[i].CustomTypeName
                     memoryrecord.ShowAsHex = currTemplate.Child[i].ShowAsHex
                     memoryrecord.ShowAsSigned = currTemplate.Child[i].ShowAsSigned
              end

              if (currTemplate.Child[i].DropDownLinked == false) and (currTemplate.Child[i].DropDownLinkedMemrec == "") then
                  memoryrecord.DropDownList.Text = currTemplate.Child[i].DropDownList.Text
                  memoryrecord.DisplayAsDropDownListItem = currTemplate.Child[i].DisplayAsDropDownListItem
              else
                  memoryrecord.DropDownLinkedMemrec = currTemplate.Child[i].DropDownLinkedMemrec
                  memoryrecord.DropDownLinked = true
              end
          end

          memoryrecord.Address = currTemplate.Child[i].Address

          if (currTemplate.Child[i].OffsetCount &gt; 0) then
             memoryrecord.OffsetCount = currTemplate.Child[i].OffsetCount

             for j = 0, currTemplate.Child[i].OffsetCount - 1, 1 do
                 memoryrecord.Offset[j] = currTemplate.Child[i].Offset[j]
             end
          end

          memoryrecord.Options = currTemplate.Child[i].Options
          memoryrecord.Color = currTemplate.Child[i].Color
          memoryrecord.DontSave = true
          memoryrecord.appendToEntry(header)

          if (currTemplate.Child[i].Count &gt; 0) then
             copyMemRecRecursive(memoryrecord, currTemplate.Child[i])
          end
      end
end

local function getMemRecTypeSize(memrec)
      local size

      if (memrec.Type == vtByte) or (memrec.Type == vtBinary) then
         size = 0x1
      elseif (memrec.Type == vtWord) then
            size = 0x2
      elseif (memrec.Type == vtDword) or (memrec.Type == vtSingle) then
            size = 0x4
      elseif (memrec.Type == vtQword) or (memrec.Type == vtDouble) then
             size = 0x8
      elseif (memrec.Type == vtString) or (memrec.Type == vtUnicodeString) or (memrec.Type == vtWideString) then
             size = memrec.String.Size
      elseif (memrec.Type == vtByteArray) then
             size = memrec.Aob.Size
      else
          print("Can't determine size of memory record, memrec: \""..memrec.Description.."\", type: \""..memrec.Type.."\", parent: \""..memrec.Parent.Description.."\"")
          size = 0x0
      end

      return size
end

local function BTSK_header(address, btsk_type)
      local base = getAddress(address)
      local size = readInteger(address)
      local BTSK_base

      for i = 1, size, 1 do
          address = address + 0x4

          BTSK_base = base + readInteger(address)
          if (readInteger(address) == 0) then
             goto continue
          end

          --BTSK_parse(BTSK_base, i)

          --characters
          if (btsk_type == 0) then
             --print("BTSK base: "..toHex(BTSK_base)..", Char: "..BTSK_char_arr[i])
             BTSK_dropdown.add(string.format("%016X", BTSK_base)..":"..BTSK_char_arr[i].." data")
          --artes
          elseif (btsk_type == 1) then
                 --print("BTSK base: "..toHex(BTSK_base)..", Arte: "..Arte_effect_dropdown_memrec.DropDownDescription[i-1])
                 BTSK_dropdown.add(string.format("%016X", BTSK_base)..":"..Arte_effect_dropdown_memrec.DropDownDescription[i-1])
          --spells
          elseif (btsk_type == 2) then
                --print("BTSK base: "..toHex(BTSK_base)..", Spell: "..Arte_effect_dropdown_memrec.DropDownDescription[i-1-155])
                BTSK_dropdown.add(string.format("%016X", BTSK_base)..":"..Arte_effect_dropdown_memrec.DropDownDescription[i-1-155])
          else
              --print("BTSK base: "..toHex(BTSK_base)..", invalid btsk type")
              BTSK_dropdown.add(string.format("%016X", BTSK_base)..":Unknown")
          end
          ::continue::
      end

end

--[[
local function BTSK_parse(address, character)
      local BTSK_entry
      local counter = 0
      address = address + 0x10

      while not (readInteger(address) == 0) do
            counter = counter + 1

            BTSK_entry = address + readInteger(address)
            --print("BTSK entry ("..counter.."): "..toHex(BTSK_entry))
            BTSK_dropdown.add(string.format("%016X", BTSK_entry)..": ("..BTSK_char_arr[character]..") "..BTSK_ptr_arr[counter])

            address = address + 0x4

      end
end
]]
local function run()
         base_address = getAddress("BTSK_v2")

         local char_btsk = readInteger(base_address + 0x4 + 0x4 * 4)
         char_btsk = base_address + char_btsk
         local arte_btsk = readInteger(base_address + 0x4 + 0x4 * 5)
         arte_btsk = base_address + arte_btsk

         BTSK_edit_memrec = getAddressList().getMemoryRecordByID("93149")
         Arte_effect_dropdown_memrec = getAddressList().getMemoryRecordByID("93254")
         BTSK_dropdown = createStringList()
         BTSK_char_arr = {"Luke","Tear","Jade","Anise","Guy","Natalia","Asch"}


         BTSK_header(char_btsk, 0) --characters
         BTSK_header(arte_btsk, 1) --artes
         --BTSK_header(base_address + 0x4BC0, 1) --artes FIX THIS LATER ------------------------------------------------
         --BTSK_header(base_spell_address, 2)--spells


         BTSK_edit_memrec.DropDownList.Text = BTSK_dropdown.Text
         BTSK_edit_memrec.DisplayAsDropDownListItem = true

         if (readQword("tbl_data+8") == 0) and (BTSK_edit_memrec.DropDownList) and (BTSK_edit_memrec.DropDownList.Count &gt; 0) then
            writeQword("tbl_data+8", tonumber(BTSK_edit_memrec.DropDownValue[0], 16))
         end

         BTSK_dropdown.Destroy()
         BTSK_dropdown = nil
end

local base_address
local Arte_effect_dropdown_memrec = getAddressList().getMemoryRecordByID("93254")
--local base_spell_address = getAddress("BTMG")
local BTSK_edit_memrec = getAddressList().getMemoryRecordByID("93149")
local BTSK_dropdown
local BTSK_char_arr

local lastValue
BTSK_edit_memrec.OnValueChanged = function(memrec, oldValue, newValue)
    if (getAddressSafe("tbl_data+8")) and
    (readInteger("tbl_data+8")) and
    not (readInteger("tbl_data+8") == 0) and
    not (lastValue == newValue) then --double run check
        lastValue = newValue
        local base = readPointer(getAddress("tbl_data+8"))
        local address = base

        local offset_0x10 = address + 0x10 --frame data
        local offset_0x14 = address + 0x14 --state machine
        local offset_0x94 = address + 0x94 --hit data
        local offset_0x98 = address + 0x98 --projectile data
        address = address + 0x8

        local entry_memrec = getAddressList().getMemoryRecordByID("93211")

        local template_frame_data_memrec = getAddressList().getMemoryRecordByID("93396")
        local template_hit_data_memrec = getAddressList().getMemoryRecordByID("93397")
        local template_state_machine_parent_memrec = getAddressList().getMemoryRecordByID("93398")
        local template_projectile_data_memrec = getAddressList().getMemoryRecordByID("134479")

        local header_frame_data_memrec = getAddressList().getMemoryRecordByID("93308")
        local header_hit_data_memrec = getAddressList().getMemoryRecordByID("93490")
        local header_state_machine_parent_memrec = getAddressList().getMemoryRecordByID("93491")
        local header_projectile_data_memrec = getAddressList().getMemoryRecordByID("135895")

        local header_size
        local work_address

        for btsk_loop = 1, 147, 1 do
            work_address = base + readInteger(address)

            if (btsk_loop == 3) then --Frame Data
                if not (readInteger(address) == 0) then
                    header_size = ((base + readInteger(offset_0x94)) - work_address) / 0x14
                else
                    header_size = 0
                end

                --delete
                for j = header_frame_data_memrec.Count, header_size + 1, -1 do
                    local rec = header_frame_data_memrec.Child[j - 1]
                    --GIGANTIC HACK TO BYPASS CHEAT ENGINE BUG AMAZING
                    if rec then
                        local t = createTimer(nil)
                        t.Interval = 1
                        t.OnTimer = function(timer)
                            timer.Destroy()
                            rec.Destroy()
                        end
                    end
                end

                --generate
                for j = header_frame_data_memrec.Count, header_size - 1, 1 do
                    local header = getAddressList().createMemoryRecord()

                    header.Description = "Frame " .. j + 1
                    header.IsGroupHeader = true
                    header.IsAddressGroupHeader = true
                    header.Address = "+14*" .. j
                    header.Options = "[moHideChildren]"
                    header.DontSave = true
                    header.appendToEntry(header_frame_data_memrec)

                    copyMemRecRecursive(header, template_frame_data_memrec)
                end
            elseif (btsk_loop &gt; 3) and (btsk_loop &lt; 36) then --State Machine
				if (btsk_loop == 4) then
				  --delete
				  for j = header_state_machine_parent_memrec.Count, 0 + 1, -1 do
					  local rec = header_state_machine_parent_memrec.Child[j - 1]
					  if rec then
						  local t = createTimer(nil)
						  t.Interval = 1
						  t.OnTimer = function(timer)
							  timer.Destroy()
							  rec.Destroy()
						  end
					  end
                      --Sleep(1)
				  end
				end

                --print("work: "..toHex(work_address)..", addr: "..toHex(address)..", loop: "..i)

				if (readInteger(address) == 0) then
				   goto _break
				end

				local loop_counter = 0

				local header = getAddressList().createMemoryRecord()

				header.Description = "State Machine "..btsk_loop - 3
				header.IsGroupHeader = true
				header.IsAddressGroupHeader = true
				header.Options = "[moHideChildren]"
				header.Address = "+"..toHex(readInteger(address))
				header.DontSave = true
				header.appendToEntry(header_state_machine_parent_memrec)

                local last_offset = work_address

				--while not (readInteger(work_address) == 0) do
                repeat
					  if (loop_counter &gt; 100) then
						 break
					  end

                      local unk_0x0 = readSmallInteger(work_address)
					  local state = readSmallInteger(work_address + 0x2)

					  if (state == 0x0) and not (unk_0x0 == 0x0) or (state &gt; 0x43) then
						 print("Invalid state found at 0x"..toHex(work_address + 0x2)..", state 0x"..toHex(state)..", skipping")
						 goto _break
					  end

					  local state_template_memrec = template_state_machine_parent_memrec.Child[state] --template memory record of the state

                      if (state_template_memrec.Count == 0) and not (state_template_memrec == template_state_machine_parent_memrec.Child[0]) then
                         print(state_template_memrec.Description.." is unknown, address: 0x"..toHex(work_address + 0x2)..", skipping")
                         goto _break
                      end

                      local state_current_final_size = 0
                      if not (state_template_memrec == template_state_machine_parent_memrec.Child[0]) then
					      state_current_final_size = getMemRecTypeSize(state_template_memrec.Child[state_template_memrec.Count - 1]) --final entry in the template memory record
                      end

					  if (state_current_final_size == 0) and not (state_template_memrec == template_state_machine_parent_memrec.Child[0]) then
                         print(state_template_memrec.Child[state_template_memrec.Count - 1].Description.." has no defined members, skipping")
						 goto _break
					  end

					  local state_next_offset = 0x0
					  if not (loop_counter == 0) then
						 --print("header_parent: "..header_state_machine_parent_memrec.Child[i - 4].Child[loop_counter - 1].Description..", header address: "..toHex(header_state_machine_parent_memrec.Child[i - 4].Child[loop_counter - 1].CurrentAddress)..", work: "..toHex(work_address)..", memrec addr: "..toHex(state_template_memrec.Child[state_template_memrec.Count - 1].CurrentAddress)..", final size: "..toHex(state_current_final_size))
                         --no idea why this doesnt work so lets hack around it
                         --state_next_offset = work_address - header_state_machine_parent_memrec.Child[i - 4].Child[loop_counter - 1].CurrentAddress
                         state_next_offset = work_address - last_offset
					  end

					  local state_header = getAddressList().createMemoryRecord()

                      local name_string = state_template_memrec.Description
                      local start_pos = string.find(name_string, "(", 1, true)

                      if (start_pos) then
                         name_string = string.sub(name_string, start_pos)
                         state_header.Description = "State "..loop_counter + 1 .." "..name_string
                      else
                          state_header.Description = "State "..loop_counter + 1
                      end
					  state_header.IsGroupHeader = true
					  state_header.IsAddressGroupHeader = true
					  state_header.Address = "+"..toHex(state_next_offset)
					  state_header.Options = "[moHideChildren]"
					  state_header.DontSave = true
					  state_header.appendToEntry(header)

					  local state_0x0 = getAddressList().createMemoryRecord()
					  state_0x0.Description = "Delay"
					  state_0x0.Address = "+0"
					  state_0x0.Type = vtWord
                      state_0x0.ShowAsSigned = true
					  state_0x0.DontSave = true
					  state_0x0.appendToEntry(state_header)

					  local state_0x2 = getAddressList().createMemoryRecord()
					  state_0x2.Description = "State"
					  state_0x2.Address = "+2"
					  state_0x2.Type = vtWord
                      state_0x2.DropDownLinkedMemrec = "dropdown: State Machine"
                      state_0x2.DropDownLinked = true
					  state_0x2.ShowAsHex = true
					  state_0x2.DontSave = true
					  state_0x2.appendToEntry(state_header)

                      if (state_template_memrec.Count == 0) then
                         if (state_template_memrec == template_state_machine_parent_memrec.Child[0]) then
                            goto _continue
                         end

                         print(state_template_memrec.Description.." is empty, skipping")
                         goto _break
                      else
					      copyMemRecRecursive(state_header, state_template_memrec)
                          work_address = work_address + state_template_memrec.Child[state_template_memrec.Count - 1].CurrentAddress + state_current_final_size
                      end

                      ::_continue::

					  loop_counter = loop_counter + 1
                until (unk_0x0 + state) == 0x0

			::_break::
            elseif (btsk_loop == 36) then --Hit Data
                if not (readInteger(address) == 0) then
                    header_size = ((base + readInteger(offset_0x98)) - work_address) / 0x24
                else
                    header_size = 0
                end

                --delete
                for j = header_hit_data_memrec.Count, header_size + 1, -1 do
                    local rec = header_hit_data_memrec.Child[j - 1]
                    if rec then
                        --local t = createTimer(nil)
                        --t.Interval = 1
                        --t.OnTimer = function(timer)
                            --timer.Destroy()
                            rec.Destroy()
                        --end
                    end
                end

                --generate
                for j = header_hit_data_memrec.Count, header_size - 1, 1 do
                    local header = getAddressList().createMemoryRecord()

                    header.Description = "Hit " .. j + 1
                    header.IsGroupHeader = true
                    header.IsAddressGroupHeader = true
                    header.Address = "+24*" .. j
                    header.Options = "[moHideChildren]"
                    header.DontSave = true
                    header.appendToEntry(header_hit_data_memrec)

                    copyMemRecRecursive(header, template_hit_data_memrec)
                end
            elseif (btsk_loop == 37) then --Projectile Data
                   --delete all children
                   for j = header_projectile_data_memrec.Count, 0 + 1, -1 do
                       local rec = header_projectile_data_memrec.Child[j - 1]
                       if rec then
                          local t = createTimer(nil)
                          t.Interval = 1
                          t.OnTimer = function(timer)
                                    timer.Destroy()
                                    rec.Destroy()
                          end
                       end
                   end

                   --"hide"
                   if (readInteger(offset_0x14) == readInteger(offset_0x98)) then
                      header_projectile_data_memrec.Color = 0xC0C0C0 --gray
                   --show
                   else
                       header_projectile_data_memrec.Color = 0xFFFFFF --natural

                       local loop_counter = 0

                       --print("addr: "..toHex(work_address)..", offset: "..toHex(readInteger(offset_0x14))..", base: "..toHex(base))
                       while (work_address &lt; base + readInteger(offset_0x14)) do
                             if (loop_counter &gt; 100) then
                                break
                             end

                             local header = getAddressList().createMemoryRecord()

                             header.Description = "Projectile Data " .. loop_counter + 1
                             header.IsGroupHeader = true
                             header.IsAddressGroupHeader = true
                             header.Address = "+7C*" .. loop_counter
                             header.Options = "[moHideChildren]"
                             header.DontSave = true
                             header.appendToEntry(header_projectile_data_memrec)

                             copyMemRecRecursive(header, template_projectile_data_memrec)

                             loop_counter = loop_counter + 1
                             work_address = work_address + 0x7C
                       end
                   end
            else
                if not (readInteger(address) == 0) then
                    print("Unknown data found at loop "..btsk_loop.." at 0x"..toHex(address)..", offset: 0x"..toHex(readInteger(address)))
                end
            end

            address = address + 0x4
        end
    end
end

--aobscanregion(BTSK_v2, baseEEmem, baseEEmem+200000000, 07 00 00 00 ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? 42 54 53 4B)
local success, result = autoAssemble([[
aobscanregion(BTSK_v2, baseEEmem, baseEEmem+200000000, 16 00 00 00 60 00 00 00)

registersymbol(BTSK_v2)
]])
if (success == true) then
   run()
else
    print(result)
    error(result)
end

{$asm}
//aobscanregion(BTSK_v2, baseEEmem, baseEEmem+200000000, 07 00 00 00 ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? ? 42 54 53 4B)
