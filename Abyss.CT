<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="45">
  <CheatEntries>
    <CheatEntry>
      <ID>69</ID>
      <Description>"Enable"</Description>
      <Options moHideChildren="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{$lua}
if syntaxcheck then return end

function toHex(str)
         return string.format("%X", str)
end

--tbl_data is at 0x10
{$asm}
[ENABLE]
{$lua}
if syntaxcheck then return end
--local attachedProc = string.sub(process,0,#process-4)
if (string.lower(process):match("pcsx2")) then
   if not (getAddressSafe("EEmem") == nil) and not (getAddressSafe("EEmem") == 0) then
        registerSymbol("baseElfAddr",readPointer(getAddress("EEmem"))+0x10008C)
        registerSymbol("baseEEmem",readPointer(getAddress("EEmem")))
   else
        print("Using fallback... this may take a few seconds")
        r,error=autoAssemble([[aobscan(baseElfAddr, 00 00 19 04 00 00 80 44 00 08 80 44 00 10 80 44 00 18 80 44)
registersymbol(baseElfAddr)]])
        if (r==false) then
           error(print(error .. "\nMake sure the game is running!"))
        end
        registerSymbol("baseEEmem",getAddress("baseElfAddr")-0x10008C)
   end

   local mf = getMainForm()
   if (mf.FromAddress.Text == "0000000000000000") and (mf.ToAddress.Text == "00007fffffffffff") then
      mf.FromAddress.Text = "baseEEmem"
      mf.ToAddress.Text = "baseEEmem+"..toHex(0x20000000)
   end
else
   error(print("Not attached to PCSX2"))
   return
end

{$asm}
alloc(tbl_data,$1000)
registersymbol(tbl_data)
[DISABLE]
unregistersymbol(baseElfAddr)
unregistersymbol(baseEEmem)
dealloc(tbl_data)
unregistersymbol(tbl_data)
</AssemblerScript>
