                          <Description>"Template"</Description>
                          <Options moHideChildren="1"/>
                          <GroupHeader>1</GroupHeader>
                          <CheatEntries>
                            <CheatEntry>
                              <ID>85417</ID>
                              <Description>"Kind"</Description>
                              <DropDownList DisplayValueAsItem="1">0:Human
1:Monster
</DropDownList>
